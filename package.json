{
  "name": "gojo-pet",
  "version": "1.0.2",
  "description": "Gojo Satoru desktop pet — Windows app built with Electron.",
  "author": "Chaitanyahoon",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.gojopet.app",
    "productName": "Gojo Pet",
    "copyright": "Copyright © 2026 Chaitanya",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gojo Pet",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "**/*",
      "!.git/**",
      "!.gitignore",
      "!**/gojo-pet.log",
      "!**/*.md",
      "!node_modules/electron-builder/**",
      "!node_modules/.cache/**",
      "!dist/**",
      "!reference_frames/**"
    ],
    "extraResources": [
      { "from": "reference_frames", "to": "reference_frames" }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Chaitanyahoon",
      "repo": "gojo-desktop",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  }
}
